{
  "name": "local_file-duckdb",
  "display_name": "Local File (DuckDB)",
  "description": "Read local files into DuckDB",
  "docs_url": "https://docs.rilldata.com/developers/build/connectors/olap/duckdb",
  "driver": "local_file",
  "olap": "duckdb",
  "tags": ["local-file", "file", "file-store", "duckdb", "source"],
  "json_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "x-category": "fileStore",
    "x-icon": "LocalFile",
    "properties": {
      "path": {
        "type": "string",
        "title": "Path",
        "description": "Local file path or glob (relative to project root)",
        "x-placeholder": "data/*.parquet",
        "x-step": "source"
      },
      "name": {
        "type": "string",
        "title": "Source name",
        "description": "Name for the source",
        "x-placeholder": "my_new_source",
        "x-step": "explorer"
      }
    },
    "required": ["path", "name"]
  },
  "files": [
    {
      "name": "model",
      "path_template": "models/[[ .model_name ]].yaml",
      "code_template": "# Model YAML\n# Reference documentation: https://docs.rilldata.com/developers/build/connectors/olap/duckdb\ntype: model\nconnector: duckdb\nsql: |\n  [[ .sql ]]\n"
    }
  ]
}
