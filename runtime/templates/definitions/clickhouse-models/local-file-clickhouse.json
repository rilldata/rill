{
  "name": "local-file-clickhouse",
  "display_name": "Local File",
  "description": "Read local files into ClickHouse",
  "driver": "local_file",
  "olap": "clickhouse",
  "tags": ["local", "file", "clickhouse", "source"],
  "json_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "x-category": "fileStore",
    "x-icon": "LocalFile",
    "x-small-icon": "LocalFileIcon",
    "properties": {
      "path": {
        "type": "string",
        "title": "Path",
        "description": "Local file path or glob (relative to project root)",
        "x-placeholder": "data/*.parquet",
        "x-step": "source"
      },
      "name": {
        "type": "string",
        "title": "Model name",
        "description": "Name for the source model",
        "pattern": "^[a-zA-Z0-9_]+$",
        "x-placeholder": "my_model",
        "x-step": "explorer"
      }
    },
    "required": ["path", "name"]
  },
  "files": [
    {
      "name": "model",
      "path_template": "models/[[ .model_name ]].yaml",
      "code_template": "# Model YAML\n# Reference documentation: https://docs.rilldata.com/reference/project-files/models\ntype: model\nmaterialize: true\nconnector: clickhouse\nsql: |\n  [[ .sql ]]\n"
    }
  ]
}
