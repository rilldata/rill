{
  "name": "gcs-clickhouse",
  "display_name": "GCS (ClickHouse)",
  "description": "Read GCS files into ClickHouse using table functions (HMAC keys)",
  "driver": "gcs",
  "olap": "clickhouse",
  "tags": ["gcs", "google", "object-storage", "clickhouse", "source"],
  "json_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "x-category": "objectStore",
    "properties": {
      "key_id": {
        "type": "string",
        "title": "HMAC Access Key",
        "description": "GCS HMAC access key ID",
        "x-placeholder": "Enter HMAC access key",
        "x-secret": true,
        "x-env-var": "GCS_KEY_ID",
        "x-step": "connector"
      },
      "secret": {
        "type": "string",
        "title": "HMAC Secret",
        "description": "GCS HMAC secret key",
        "x-placeholder": "Enter HMAC secret",
        "x-secret": true,
        "x-env-var": "GCS_SECRET",
        "x-step": "connector"
      },
      "path": {
        "type": "string",
        "title": "GCS URI",
        "description": "Path to your GCS bucket or prefix",
        "pattern": "^gs://[^/]+(/.*)?$",
        "errorMessage": { "pattern": "Must be a GCS URI (e.g. gs://bucket/path)" },
        "x-placeholder": "gs://bucket/path",
        "x-step": "source"
      },
      "name": {
        "type": "string",
        "title": "Model name",
        "description": "Name for the source model",
        "pattern": "^[a-zA-Z0-9_]+$",
        "x-placeholder": "my_model",
        "x-step": "explorer"
      }
    },
    "required": ["key_id", "secret", "path", "name"]
  },
  "files": [
    {
      "name": "model",
      "path_template": "models/[[ .model_name ]].yaml",
      "code_template": "# Model YAML\n# Reference documentation: https://docs.rilldata.com/reference/project-files/models\ntype: model\nmaterialize: true\nconnector: clickhouse\nsql: |\n  [[ .sql ]]\n"
    }
  ]
}
